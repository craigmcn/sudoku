rules_version = '2';

// Not deployed via CLI yet (no Firebase CLI wiring in this repo) — paste this
// into Firebase Console → Firestore Database → Rules → Publish. Keep this
// file as the source of truth and re-paste it whenever it changes.
service cloud.firestore {
  match /databases/{database}/documents {

    // puzzles/{puzzleId} — puzzleId is hashSolution() from src/puzzleId.ts.
    // Anyone signed in (including anonymous, see #17) may create a puzzle
    // doc the first time it's generated, and may bump the play counters on
    // an existing one — nothing else. `create` only ever matches a doc that
    // doesn't already exist, so a duplicate generation naturally falls
    // through to the `update` (counter-only) branch instead.
    //
    // `puzzle` must be 9 strings (one per row, 9 chars each, '0' for blank)
    // rather than a 9x9 nested array — Firestore rejects nested arrays
    // outright (confirmed via smoke test against this project). `is list`
    // below passes either way; the row-strings shape is enforced by the
    // writer, not these rules.
    //
    // `puzzleId` is not validated as the actual hashSolution() output of the
    // submitted puzzle — rules can't recompute that hash, so this is an
    // accepted trust boundary, not an oversight. A malicious client could in
    // principle squat on a future puzzle's ID with junk content; low-risk
    // for a hobby-scale, non-adversarial project.
    match /puzzles/{puzzleId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
             'difficulty', 'puzzle', 'solutionHash', 'timesPlayed',
             'totalPlayTimeMs', 'completions', 'isDaily', 'createdAt', 'dailyDate'
           ])
        && request.resource.data.difficulty in ['easy', 'normal', 'hard', 'expert']
        && request.resource.data.puzzle is list
        && request.resource.data.solutionHash is string
        && request.resource.data.timesPlayed == 0
        && request.resource.data.totalPlayTimeMs == 0
        && request.resource.data.completions == 0
        && request.resource.data.isDaily is bool;

      // Counter-only updates: fields must stay integers, and each write may
      // only move a counter by a bounded amount — timesPlayed/completions by
      // at most 1 (one play session per write), totalPlayTimeMs by at most
      // 6 hours (21600000ms) as a sanity ceiling against a fat-fingered or
      // malicious jump, while still generous for a real long session.
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['timesPlayed', 'totalPlayTimeMs', 'completions'])
        && request.resource.data.timesPlayed is int
        && request.resource.data.totalPlayTimeMs is int
        && request.resource.data.completions is int
        && request.resource.data.timesPlayed >= resource.data.timesPlayed
        && request.resource.data.timesPlayed <= resource.data.timesPlayed + 1
        && request.resource.data.totalPlayTimeMs >= resource.data.totalPlayTimeMs
        && request.resource.data.totalPlayTimeMs <= resource.data.totalPlayTimeMs + 21600000
        && request.resource.data.completions >= resource.data.completions
        && request.resource.data.completions <= resource.data.completions + 1;

      allow delete: if false;
    }

    // dailyPuzzles/{yyyy-mm-dd} — created once, by whichever client asks for
    // that date first; immutable after that so everyone sees the same
    // puzzle for the day.
    //
    // The easy/normal/hard/expert/random values aren't checked against
    // existing puzzles/{puzzleId} docs — a get()-based existence check is
    // possible but costs an extra read per field, which isn't worth it at
    // this project's scale. Accepted trade-off, not an oversight.
    match /dailyPuzzles/{date} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['easy', 'normal', 'hard', 'expert', 'random'])
        && request.resource.data.easy is string
        && request.resource.data.normal is string
        && request.resource.data.hard is string
        && request.resource.data.expert is string
        && request.resource.data.random is string;

      allow update: if false;
      allow delete: if false;
    }

    // users/{uid}/plays/{puzzleId} — per-user play history (#26). Only the
    // owning uid (anonymous or a real linked account, see #17/#25) may read
    // or write their own history; nobody else can even read it.
    //
    // Doc ID is puzzleId, not an auto-ID: replaying the same puzzle
    // overwrites the previous entry for it rather than accumulating one doc
    // per attempt — see CLAUDE.md for why. That means create and update need
    // the same validation, since a client can't tell in advance which one a
    // given write will be.
    //
    // completedAt must equal request.time (the serverTimestamp() sentinel's
    // resolved value at request evaluation) so a client can't backdate or
    // fabricate the timestamp.
    match /users/{uid}/plays/{puzzleId} {
      allow read: if request.auth != null && request.auth.uid == uid;

      allow create, update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
             'difficulty', 'mistakes', 'elapsedMs', 'completedAt'
           ])
        && request.resource.data.difficulty in ['easy', 'normal', 'hard', 'expert']
        && request.resource.data.mistakes is int
        && request.resource.data.mistakes >= 0
        && request.resource.data.elapsedMs is int
        && request.resource.data.elapsedMs >= 0
        && request.resource.data.elapsedMs <= 21600000
        && request.resource.data.completedAt == request.time;

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
